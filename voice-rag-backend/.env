# ─────────────────────────────────────────────────────────
#  Voice RAG Assistant — Environment Configuration
#  No API keys needed. Everything runs locally via Ollama.
# ─────────────────────────────────────────────────────────

# Ollama server (runs on your machine)
OLLAMA_BASE_URL=http://localhost:11434

# LLM model for generating answers
# Options: llama3.2:3b (fast, 4GB RAM) | mistral:7b (better, 8GB RAM)
LLM_MODEL=phi3:mini

# Embedding model for RAG document search
# Must match the model used during ingest
EMBED_MODEL=nomic-embed-text

# Local ChromaDB vector store path
CHROMA_DIR=./chroma_db

# Folder where your PDF/TXT documents live
DOCS_DIR=./docs

# Max conversation turns kept per session (each turn = 1 user + 1 bot message)
MAX_TURNS=10

# CORS — allow all origins for local dev
# Change to your frontend URL in production
ALLOWED_ORIGIN=*
